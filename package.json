{
  "name": "tillas-ec",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/web",
    "apps/admin"
  ],
  "scripts": {
    "dev:api": "cd packages/api && npm run start:dev",
    "dev:web": "cd apps/web && npm run dev",
    "dev:admin": "cd apps/admin && npm run dev",
    "dev:mobile": "cd apps/mobile && npx expo start",
    "db:generate": "cd packages/database && npx prisma generate",
    "db:migrate": "cd packages/database && npx prisma migrate dev",
    "db:seed": "cd packages/database && npx prisma db seed",
    "db:studio": "cd packages/database && npx prisma studio",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up -d",
    "docker:prod": "docker-compose up -d",
    "docker:down": "docker-compose -f docker-compose.dev.yml down",
    "lint": "eslint 'packages/**/src/**/*.ts' 'apps/**/src/**/*.ts' 'apps/**/*.tsx' --fix",
    "lint:check": "eslint 'packages/**/src/**/*.ts' 'apps/**/src/**/*.ts' 'apps/**/*.tsx'",
    "format": "prettier --write 'packages/**/*.{ts,tsx,json}' 'apps/**/*.{ts,tsx,json}' '!**/node_modules/**'",
    "format:check": "prettier --check 'packages/**/*.{ts,tsx,json}' 'apps/**/*.{ts,tsx,json}' '!**/node_modules/**'",
    "test:api": "cd packages/api && npm test",
    "test:api:cov": "cd packages/api && npm run test:cov",
    "test:api:e2e": "cd packages/api && npm run test:e2e",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.2.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
