# ==========================================
# TILLAS.EC — Variables de Entorno
# ==========================================
# Copia este archivo a .env y llena los valores.
#
# Nota:
# - Para desarrollo local con API fuera de Docker usa localhost.
# - Para Dokploy/Compose usa hosts internos de servicio (postgres, redis, minio o nombre del servicio en Dokploy).

# === Base de Datos ===
DB_USER=tillas_user
DB_PASSWORD=your_secure_password_here
DB_NAME=tillas
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}

# === JWT ===
JWT_SECRET=your_jwt_secret_minimum_32_chars_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_minimum_32_chars_here
JWT_REFRESH_EXPIRES_IN=30d

# === Google OAuth2 ===
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# === Pagos - Transferencia Bancaria ===
# Datos de la cuenta bancaria para recibir transferencias
BANK_NAME=Banco Pichincha
BANK_ACCOUNT=2209004611
BANK_ACCOUNT_TYPE=Ahorros
BANK_HOLDER=BRANDON JOEL
BANK_ID_NUMBER=

# === Minio (S3 Self-hosted) ===
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=tillas_minio_access
MINIO_SECRET_KEY=tillas_minio_secret_key
MINIO_BUCKET=tillas-media
MINIO_PUBLIC_URL=https://media.tillas.ec

# === Firebase (Push Notifications) ===
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=your_firebase_client_email

# === Telegram (Sincronización con Proveedor) ===
# Obtener API_ID y API_HASH de https://my.telegram.org
TELEGRAM_API_ID=31423016
TELEGRAM_API_HASH=a9613469907d76eb466aadff0c526966
TELEGRAM_STRING_SESSION=              # Generar con: npx ts-node scripts/telegram-session.ts
TELEGRAM_CHANNEL_USERNAME=rancyd      # Username del canal del proveedor

# === SMTP (Emails) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@ejemplo.com
SMTP_PASS=tu_password_de_app
SMTP_FROM=noreply@tillas.ec

# === App Config ===
NODE_ENV=development
API_PORT=4000
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# === Mobile Config ===
EXPO_PUBLIC_API_URL=http://localhost:4000

# ==========================================
# Perfil recomendado para PRODUCCION (Dokploy)
# Descomenta y ajusta estos valores al desplegar
# ==========================================
# NODE_ENV=production
# DB_HOST=postgres
# DB_PORT=5432
# DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}
# MINIO_ENDPOINT=minio
# MINIO_PORT=9000
# API_URL=https://api.tillas.ec
# WEB_URL=https://tillas.ec
# ADMIN_URL=https://admin.tillas.ec
# EXPO_PUBLIC_API_URL=https://api.tillas.ec
